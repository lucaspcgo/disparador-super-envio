# =============================================================================
# Super Envio — variáveis de ambiente
# =============================================================================
# Copie para .env.local (dev) e preencha. Em produção (EasyPanel/Vercel/etc.)
# use o painel de Environment do servidor — NUNCA versione .env.local.
# Chaves com prefixo NEXT_PUBLIC_ vão para o browser; as demais são SERVER-ONLY.
# =============================================================================

# --- Supabase (OBRIGATÓRIO) -------------------------------------------------
# Painel: https://supabase.com/dashboard/project/<seu-projeto>/settings/api
# Use o projeto onde as migrations (0001–0004) foram aplicadas.
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
# Publishable/anon key (pode ir ao browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret/service_role key — SERVER-ONLY (bypassa RLS; usada só para decriptar
# credenciais no Vault). NUNCA prefixe com NEXT_PUBLIC_ e nunca exponha.
SUPABASE_SERVICE_ROLE_KEY=

# --- Evolution API gerenciada (OBRIGATÓRIO p/ provedor "gerenciado") --------
# Host da SUA instância Evolution administrável + a global API key (admin).
# SERVER-ONLY. (Provedor BYO e Meta não usam isto — são credenciais por-instância.)
EVOLUTION_MANAGED_URL=https://<seu-host-evolution>
EVOLUTION_MANAGED_GLOBAL_KEY=
